{
  "name": "@react-navigation/native-stack",
  "description": "Native stack navigator using react-native-screens",
  "version": "8.0.0-alpha.47",
  "keywords": [
    "react-native-component",
    "react-component",
    "react-native",
    "react-navigation",
    "ios",
    "android",
    "native",
    "stack"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-navigation/react-navigation.git",
    "directory": "packages/native-stack"
  },
  "bugs": {
    "url": "https://github.com/software-mansion/react-native-screens/issues"
  },
  "homepage": "https://github.com/software-mansion/react-native-screens#readme",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "@react-navigation/source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "bob build",
    "clean": "del lib"
  },
  "dependencies": {
    "@react-navigation/elements": "workspace:^",
    "warn-once": "^0.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@react-navigation/native": "workspace:^",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "~19.2.17",
    "del-cli": "^7.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.43.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.26.2",
    "react-native-web": "~0.21.2",
    "test-renderer": "1.2.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@react-navigation/native": "workspace:^",
    "react": ">= 19.2.0",
    "react-native": "*",
    "react-native-safe-area-context": ">= 5.5.0",
    "react-native-screens": ">= 4.25.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
