{
  "name": "@react-navigation/example",
  "description": "Demo app to showcase various functionality of React Navigation",
  "private": true,
  "main": "./App.tsx",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "vite",
    "server": "babel-node -i '/node_modules[/\\\\](?react-native)/' -x '.web.tsx,.web.ts,.web.js,.tsx,.ts,.js' --config-file ./server/babel.config.js server",
    "e2e:native": "node ../scripts/maestro.ts",
    "e2e:web": "npx playwright test --config=e2e/playwright.config.ts"
  },
