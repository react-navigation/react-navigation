{
  "name": "@react-navigation/example",
  "description": "Demo app to showcase various functionality of React Navigation",
  "version": "5.1.0",
  "private": true,
  "main": "./App.tsx",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "server": "nodemon -e '.js,.ts,.tsx' --exec \"babel-node -i '/node_modules[/\\](?react-native)/' -x '.web.tsx,.web.ts,.web.js,.tsx,.ts,.js' --config-file ./server/babel.config.js server\"",
    "e2e:web": "npx playwright test --config=e2e/playwright.config.ts",
    "e2e:native": "maestro test -e APP_ID=host.exp.exponent e2e/maestro"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.17",
    "@expo/react-native-action-sheet": "^4.1.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "color": "^4.2.3",
    "expo": "56.0.12",
    "expo-asset": "~56.0.20",
    "expo-blur": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-navigation-bar": "~56.0.3",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.22",
    "koa": "^3.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.26.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "standard-navigation": "^0.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.28.0",
    "@babel/plugin-transform-strict-mode": "^7.27.1",
    "@playwright/test": "^1.53.0",
    "@react-native/metro-config": "0.85.3",
    "@types/cheerio": "^0.22.35",
    "@types/koa": "^2.15.0",
    "@types/mock-require": "^3.0.0",
    "@types/react": "~19.2.4",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~56.0.0",
    "cheerio": "^1.1.0",
    "expect-type": "^1.2.1",
    "expo-build-disk-cache": "^0.7.2",
    "mock-require-assets": "^0.0.3",
    "nodemon": "^3.1.10",
    "npm-run-all2": "^8.0.4",
    "react-native-builder-bob": "^0.42.1",
    "react-native-monorepo-config": "^0.3.5",
    "react-test-renderer": "19.2.3",
    "serve": "^14.2.5",
    "typescript": "~6.0.3",
    "yaml": "^2.8.0"
  }
}
